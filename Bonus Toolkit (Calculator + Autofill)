    // ─── BUTTON ──────────────────────────────────────────────────────────────

    function addCalculatorButton() {
        if (!getCurrentPlayerId()) {
            const existing = document.getElementById('tm-bonus-btn');
            if (existing) existing.remove();
            return;
        }
        if (document.getElementById('tm-bonus-btn')) return;
        injectStyles();

        const btn = document.createElement('button');
        btn.id = 'tm-bonus-btn';
        btn.innerHTML = '<span class="tm-dot"></span> Bonus Calc';
        btn.addEventListener('click', () => runCalculator(btn));
        document.body.appendChild(btn);
    }

    function setButtonLoading(btn, label) {
        btn.disabled = true;
        btn.classList.add('tm-loading');
        btn.innerHTML = `<span class="tm-dot"></span> ${label}`;
    }

    function resetButton(btn) {
        btn.disabled = false;
        btn.classList.remove('tm-loading');
        btn.innerHTML = '<span class="tm-dot"></span> Bonus Calc';
    }

    // ─── DATE HELPERS ─────────────────────────────────────────────────────────

    function parseLocalDate(str) {
        const [datePart, timePart] = str.trim().split(' ');
        const [y, mo, d] = datePart.split('-').map(Number);
        const [h, mi, s] = (timePart || '00:00:00').split(':').map(Number);
        return new Date(y, mo - 1, d, h, mi, s).getTime();
    }

    function formatDate(str) {
        return str.trim().slice(0, 16);
    }

    // ─── MAIN FLOW ───────────────────────────────────────────────────────────

    async function runCalculator(btn) {
        setButtonLoading(btn, 'Checking…');

        try {
            // 1. Blocking tags
            const tags = getPlayerTags();
            const blockingTags = BLOCKING_TAGS.filter(t => tags.includes(t));
            if (blockingTags.length) {
                return showBlocked(blockingTags);
            }

            // 2. Account stats
            const account = getAccountStats();
            if (!account) {
                return showError('Could not read account statistics. Make sure you are on a player page.');
            }

            // 3. Crypto rate
            let usdRate = null;
            if (isCryptoCurrency(account.currency)) {
                setButtonLoading(btn, 'Fetching rate…');
                usdRate = await fetchUsdRate(account.currency);
                if (!usdRate) {
                    return showError(`Could not fetch a USD rate for ${account.currency}. Try again in a moment — CoinGecko may be rate-limiting or unreachable.`);
                }
            }

            const balanceUsd = usdRate ? account.balance * usdRate : account.balance;

            // 4. Basic eligibility checks
            const checks = [
                {
                    label: usdRate
                        ? `Balance: ${account.balance} ${account.currency} (≈ ${balanceUsd.toFixed(2)} USD)`
                        : `Balance: ${account.balance} ${account.currency}`,
                    pass: balanceUsd < 1
                },
                { label: `Pending cashouts: ${account.pending}`, pass: account.pending === 0 },
                {
                    label: `Spent in casino: ${account.spent} ${account.currency}`,
                    pass: account.spentGreen && account.spent > 0
                },
                { label: `Bonus ratio: ${account.bonusRatio}%`, pass: account.bonusRatio < 50 }
            ];

            const failed = checks.filter(c => !c.pass);
            if (failed.length) {
                return showIneligible(checks, null, null, null, null);
            }

            // 5. Expand payments
            setButtonLoading(btn, 'Loading payments…');
            const expandResult = await expandPaymentsPerPage();
            const expandWarning = (!expandResult.expanded && expandResult.reason === 'timeout')
                ? 'Payments table may not have fully expanded to 100/page (timed out). Results may be based on an incomplete list — try running again or set 100/page manually first.'
                : null;

            // 6. Last qualifying bonus
            const lastBonus = getLastQualifyingBonusDate();
            if (!lastBonus) {
                return showError('No Personal, Deposit, or Loyalty FS Bgaming bonus found in Issued Bonuses / Issued Freespins.');
            }

            // 7. Payments + deposits
            const payments = getPaymentRows();
            const startInfo = getStartAfterCashout(payments, lastBonus.ts);
            const deposits = payments.filter(p =>
                p.action === 'Deposit' && p.success && p.ts > startInfo.ts
            );
            const total = deposits.reduce((sum, p) => sum + p.amount, 0);
            const totalUsd = usdRate ? total * usdRate : total;

            if (deposits.length === 0 || total <= 0) {
                return showNoDeposits(lastBonus, startInfo, usdRate, account.currency);
            }

            // 8. Reward
            const roundUp5 = n => Math.ceil(n / 5) * 5;
            let rewardAmount, rewardAmountUsd, rewardLabel, rewardKind;

            if (totalUsd < 100) {
                rewardKind = 'freespins';
                rewardAmountUsd = roundUp5(Math.ceil(totalUsd / 2));
                rewardAmount = rewardAmountUsd; // plain spin count, never crypto-denominated
                rewardLabel = `${rewardAmount} free spins`;
            } else {
                rewardKind = 'bonus';
                rewardAmountUsd = roundUp5(Math.ceil(totalUsd * 0.10));
                // Round here, once, at the source — this is the exact value
                // that gets stored AND displayed, so there's no drift between
                // what the panel shows and what the popup autofills.
                rewardAmount = usdRate ? roundCrypto(rewardAmountUsd / usdRate) : rewardAmountUsd;
                const nativeFmt = usdRate
                    ? rewardAmount.toFixed(8).replace(/0+$/, '').replace(/\.$/, '')
                    : String(rewardAmount);
                rewardLabel = usdRate
                    ? `${nativeFmt} ${account.currency} (≈ ${rewardAmountUsd} USD)`
                    : `${rewardAmount} ${account.currency}`;
            }

            const escalate = rewardAmountUsd > 200;

            lastCalcResult = {
                playerId: getCurrentPlayerId(),
                currency: account.currency,
                rewardAmount,
                rewardType: rewardKind,
                calculatedAt: Date.now()
            };

            showEligible({
                checks,
                lastBonus,
                startInfo,
                deposits,
                total,
                totalUsd,
                usdRate,
                currency: account.currency,
                rewardLabel,
                rewardKind,
                escalate,
                expandWarning
            });

        } finally {
            resetButton(btn);
        }
    }

    // ─── PLAYER TAGS ─────────────────────────────────────────────────────────

    function getPlayerTags() {
        const el = document.getElementById('user_tags');
        if (!el) return [];
        try { return JSON.parse(el.dataset.tags || '[]'); } catch { return []; }
    }

    // ─── ACCOUNT STATISTICS ──────────────────────────────────────────────────

    function getAccountStats() {
        const row = document.querySelector('.account_statistics tbody tr:has(.status_tag.yes)');
        if (!row) return null;

        const balance = parseFloat(row.querySelector('.col-balance')?.innerText.replace(/[^\d.]/g, '')) || 0;
        const pending = parseFloat(row.querySelector('.col-pending_cashouts_sum')?.innerText.replace(/[^\d.]/g, '')) || 0;
        const spentCell = row.querySelector('.col-spent_in_casino');
        const spent = parseFloat(spentCell?.innerText.replace(/[^\d.]/g, '')) || 0;
        const spentGreen = !!spentCell?.querySelector('.green');
        const bonusRatio = parseFloat(row.querySelector('.col-bonus_ratio')?.innerText.replace('%', '')) || 0;
        const currency = row.querySelector('.col-currency .status_tag.yes')?.innerText.trim() || '';

        return { balance, pending, spent, spentGreen, bonusRatio, currency };
    }

    // ─── LATEST QUALIFYING BONUS ──────────────────────────────────────────────

    function getLastQualifyingBonusDate() {
        let latest = null;
        const consider = (str, ts, kind) => {
            if (!latest || ts > latest.ts) latest = { str, ts, kind };
        };

        document.querySelectorAll('#js-player-bonus-issues-table tbody tr').forEach(row => {
            const strategy = row.querySelector('.col-strategy')?.innerText.trim();
            if (strategy !== 'Personal' && strategy !== 'Deposit') return;
            const str = row.querySelector('.col-issued_at')?.innerText.trim();
            if (str) consider(str, parseLocalDate(str), strategy);
        });

        document.querySelectorAll('#js-player-freespin-issues-table tbody tr').forEach(row => {
            const strategy = row.querySelector('.col-strategy')?.innerText.trim();
            const bonusName = row.querySelector('.col-freespin_bonus')?.innerText.trim() || '';
            let kind = null;
            if (strategy === 'Personal' || strategy === 'Deposit') kind = strategy;
            else if (bonusName.includes('Loyalty FS Bgaming')) kind = 'Loyalty FS Bgaming';
            if (!kind) return;
            const str = row.querySelector('.col-issued_at')?.innerText.trim();
            if (str) consider(str, parseLocalDate(str), kind);
        });

        return latest;
    }

    // ─── EXPAND PAYMENTS TO 100/PAGE ─────────────────────────────────────────

    function expandPaymentsPerPage() {
        const links = document.querySelectorAll('a[href*="toggle_payments?payments_per_page=100"]');
        if (!links.length) return Promise.resolve({ expanded: true, reason: 'no_control' });

        const before = document.querySelectorAll('#js-player-payments-table tbody tr').length;

        // Default page size is 10 — fewer than 10 rows means all payments
        // are already visible, no point clicking expand.
        if (before < 10) return Promise.resolve({ expanded: true, reason: 'already_complete' });

        links[0].click();

        return new Promise(resolve => {
            let tries = 0;
            const maxTries = 150;
            const interval = setInterval(() => {
                const table = document.getElementById('js-player-payments-table');
                const after = table ? table.querySelectorAll('tbody tr').length : 0;
                tries++;
                if (after > before) {
                    clearInterval(interval);
                    resolve({ expanded: true, reason: 'grew', rows: after });
                    return;
                }
                if (tries > maxTries) {
                    clearInterval(interval);
                    resolve({ expanded: false, reason: 'timeout', rows: after });
                }
            }, 200);
        });
    }

    // ─── READ PAYMENT ROWS ───────────────────────────────────────────────────

    function getPaymentRows() {
        const results = [];
        document.querySelectorAll('#js-player-payments-table tbody tr').forEach(row => {
            const actionCell = row.querySelector('.col-action a');
            if (!actionCell) return;
            const action = actionCell.innerText.trim();
            const successSpan = row.querySelector('.col-success .status_tag');
            const success = successSpan?.innerText.trim().toLowerCase() === 'yes';
            const str = row.querySelector('.col-created_at')?.innerText.trim();
            if (!str) return;
            const ts = parseLocalDate(str);
            const amount = parseFloat(row.querySelector('.col-amount')?.innerText.trim().replace(/[^\d.]/g, '')) || 0;
            results.push({ action, success, str, ts, amount });
        });
        return results;
    }

    // ─── START DATE ───────────────────────────────────────────────────────────

    function getStartAfterCashout(payments, bonusTs) {
        let latest = null;
        payments.forEach(p => {
            if (p.action === 'Cashout' && p.success && p.ts > bonusTs) {
                if (!latest || p.ts > latest.ts) latest = { str: p.str, ts: p.ts };
            }
        });
        return latest || { str: '', ts: bonusTs };
    }

    // ─── UI HELPERS ───────────────────────────────────────────────────────────

    function showOverlay(innerHTML) {
        const existing = document.getElementById('tm-bonus-overlay');
        if (existing) existing.remove();

        const overlay = document.createElement('div');
        overlay.id = 'tm-bonus-overlay';
        overlay.innerHTML = `<div id="tm-bonus-panel">${innerHTML}</div>`;

        overlay.addEventListener('click', e => { if (e.target === overlay) overlay.remove(); });
        overlay.querySelector('.tm-close-btn')?.addEventListener('click', () => overlay.remove());

        document.body.appendChild(overlay);
    }

    function checkListHTML(checks) {
        return `<ul class="tm-checks">
            ${checks.map(c => `
                <li>
                    <span class="tm-ci ${c.pass ? 'tm-ci-ok' : 'tm-ci-fail'}">${c.pass ? '✔' : '✕'}</span>
                    ${c.label}
                </li>
            `).join('')}
        </ul>`;
    }

    // ─── DISPLAY STATES ──────────────────────────────────────────────────────

    function showBlocked(blockingTags) {
        showOverlay(`
            <div class="tm-panel-header">
                <span class="tm-badge tm-badge-blocked">⛔ Blocked</span>
                <button class="tm-close-btn" aria-label="Close">✕</button>
            </div>
            <div class="tm-panel-body">
                <div class="tm-blocked-msg">
                    Player has restricted tag(s): <strong>${blockingTags.join(', ')}</strong><br><br>
                    Bonus eligibility was not calculated. Manager approval required.
                </div>
            </div>
        `);
    }

    function showError(message) {
        showOverlay(`
            <div class="tm-panel-header">
                <span class="tm-badge tm-badge-danger">✕ Error</span>
                <button class="tm-close-btn" aria-label="Close">✕</button>
            </div>
            <div class="tm-panel-body">
                <div class="tm-blocked-msg">${message}</div>
            </div>
        `);
    }

    function showIneligible(checks) {
        showOverlay(`
            <div class="tm-panel-header">
                <span class="tm-badge tm-badge-danger">✕ Not eligible</span>
                <button class="tm-close-btn" aria-label="Close">✕</button>
            </div>
            <div class="tm-panel-body">
                ${checkListHTML(checks)}
            </div>
        `);
    }

    function showNoDeposits(lastBonus, startInfo, usdRate, currency) {
        const fromLine = startInfo.ts > lastBonus.ts
            ? `Deposits counted from after cashout: <strong>${formatDate(startInfo.str)}</strong>`
            : `Deposits counted from after bonus date`;

        showOverlay(`
            <div class="tm-panel-header">
                <span class="tm-badge tm-badge-danger">✕ Not eligible</span>
                <button class="tm-close-btn" aria-label="Close">✕</button>
            </div>
            <div class="tm-panel-body">
                <div class="tm-meta">
                    Last qualifying bonus <strong>(${lastBonus.kind})</strong>: ${formatDate(lastBonus.str)}<br>
                    ${fromLine}<br><br>
                    No successful deposits found after that date.
                    ${usdRate ? `<br><br>Rate used: 1 ${currency} ≈ ${usdRate} USD` : ''}
                </div>
            </div>
        `);
    }

    function showEligible({ checks, lastBonus, startInfo, deposits, total, totalUsd, usdRate, currency, rewardLabel, rewardKind, escalate, expandWarning }) {
        const fmtNative = n => usdRate
            ? n.toFixed(8).replace(/0+$/, '').replace(/\.$/, '')
            : n.toFixed(2);

        const depositRows = deposits.map(d => `
            <div class="tm-dep-row">
                <span>${formatDate(d.str)}</span>
                <span class="tm-dep-amt">+${fmtNative(d.amount)} ${currency}${usdRate ? ` <span style="color:#57606a;font-weight:400;">(≈${(d.amount * usdRate).toFixed(2)} USD)</span>` : ''}</span>
            </div>
        `).join('');

        const totalLine = usdRate
            ? `${fmtNative(total)} ${currency} <span style="color:#57606a;">(≈ ${totalUsd.toFixed(2)} USD)</span>`
            : `${total.toFixed(2)} ${currency}`;

        const fromLine = startInfo.ts > lastBonus.ts
            ? `Counted from after cashout: <strong>${formatDate(startInfo.str)}</strong>`
            : `Counted from after last bonus`;

        const rewardIcon = rewardKind === 'freespins' ? '🎰' : '💰';

        const escalateBanner = escalate ? `
            <div class="tm-escalate">
                ⚠️ Escalate to VIP — reward exceeds 200 USD equivalent
            </div>` : '';

        const warnBanner = expandWarning ? `
            <div class="tm-warn">
                ⚠️ ${expandWarning}
            </div>` : '';

        showOverlay(`
            <div class="tm-panel-header">
                <span class="tm-badge tm-badge-success">✔ Eligible</span>
                <button class="tm-close-btn" aria-label="Close">✕</button>
            </div>
            <div class="tm-panel-body">
                ${checkListHTML(checks)}
                <div class="tm-divider"></div>
                <div class="tm-meta">
                    Last bonus <strong>(${lastBonus.kind})</strong>: ${formatDate(lastBonus.str)}<br>
                    ${fromLine}
                </div>
                <div class="tm-deposits">
                    ${depositRows}
                    <div class="tm-dep-total">
                        <span>Total</span>
                        <span>${totalLine}</span>
                    </div>
                </div>
                <div class="tm-reward">
                    <div>
                        <div class="tm-reward-label">Reward</div>
                        <div class="tm-reward-value">${rewardLabel}</div>
                    </div>
                    <span class="tm-reward-icon">${rewardIcon}</span>
                </div>
                ${escalateBanner}
                ${warnBanner}
            </div>
        `);
    }


    // ════════════════════════════════════════════════════════════════════════
    // SECTION 2 — PERSONAL BONUS POPUP AUTOFILL
    // ════════════════════════════════════════════════════════════════════════

    function autofillPersonalBonus() {
        const bonus = document.getElementById('bonus_issue_bonus');
        if (bonus && !bonus.value) {
            bonus.value = 'Personal Bonus';
            bonus.dispatchEvent(new Event('input', { bubbles: true }));
            bonus.dispatchEvent(new Event('change', { bubbles: true }));
        }

        const activeCurrency = document.querySelector('td.col-currency a.status_tag.yes');
        const currencySelect = document.getElementById('bonus_issue_currency');
        if (activeCurrency && currencySelect && !currencySelect.value) {
            const currency = activeCurrency.textContent.trim();
            if ([...currencySelect.options].some(o => o.value === currency)) {
                currencySelect.value = currency;
                currencySelect.dispatchEvent(new Event('change', { bubbles: true }));
            }
        }

        const wager = document.getElementById('bonus_issue_wager_multiplier');
        if (wager && !wager.value) {
            wager.value = '40';
            wager.dispatchEvent(new Event('input', { bubbles: true }));
            wager.dispatchEvent(new Event('change', { bubbles: true }));
        }

        const validUntil = document.getElementById('bonus_issue_valid_until');
        if (validUntil && !validUntil.value) {
            const date = new Date();
            date.setDate(date.getDate() + 7);
            validUntil.value = date.toISOString().split('T')[0];
            validUntil.dispatchEvent(new Event('input', { bubbles: true }));
            validUntil.dispatchEvent(new Event('change', { bubbles: true }));
        }

        const amount = document.getElementById('bonus_issue_amount');
        if (amount && !amount.dataset.focused) {
            if (!amount.value) {
                const storedAmount = getStoredRewardAmount('bonus');
                if (storedAmount) {
                    // storedAmount is already rounded to 8 decimals at the
                    // source (see roundCrypto) — format here only strips
                    // trailing zeros for display, it does not re-round.
                    amount.value = Number(storedAmount.toFixed(8));
                    amount.dispatchEvent(new Event('input', { bubbles: true }));
                    amount.dispatchEvent(new Event('change', { bubbles: true }));
                }
            }
            amount.focus();
            amount.dataset.focused = '1';
        }

        const comment = document.getElementById('bonus_issue_comment');
        if (comment && !comment.value) {
            comment.value = 'losses';
            comment.dispatchEvent(new Event('input', { bubbles: true }));
            comment.dispatchEvent(new Event('change', { bubbles: true }));
        }
    }


    // ════════════════════════════════════════════════════════════════════════
    // SECTION 3 — FREESPINS POPUP AUTOFILL
    // ════════════════════════════════════════════════════════════════════════

    function getActiveCurrencyForFreespins(form) {
        const activeCurrency = document.querySelector('td.col-currency a.status_tag.yes');
        if (activeCurrency) return activeCurrency.textContent.trim();
        if (form?.dataset.playerProfileCurrency) return form.dataset.playerProfileCurrency.trim();
        return null;
    }

    function autofillFreespins() {
        const form = document.getElementById('js_issue_freespins_form');
        if (!form) return;

        const bonusSelect = document.getElementById('freespin_issue_freespin_bonus_id');
        if (bonusSelect && !bonusSelect.value) {
            const currency = getActiveCurrencyForFreespins(form);
            if (currency) {
                const target = `${currency} Loyalty FS Bgaming ${currency}`;
                const option = [...bonusSelect.options].find(o => o.textContent.trim() === target);
                if (option) {
                    bonusSelect.value = option.value;
                    bonusSelect.dispatchEvent(new Event('change', { bubbles: true }));
                }
            }
        }

        const spinsCount = document.getElementById('freespin_issue_spins_count');
        if (spinsCount && !spinsCount.value && !spinsCount.dataset.autofilled) {
            const storedCount = getStoredRewardAmount('freespins');
            if (storedCount) {
                spinsCount.value = storedCount;
                spinsCount.dispatchEvent(new Event('input', { bubbles: true }));
                spinsCount.dispatchEvent(new Event('change', { bubbles: true }));
            }
            spinsCount.dataset.autofilled = '1';
        }

        const comment = document.getElementById('freespin_issue_comment');
        if (comment && !comment.value) {
            comment.value = 'ly';
            comment.dispatchEvent(new Event('input', { bubbles: true }));
            comment.dispatchEvent(new Event('change', { bubbles: true }));
        }
    }


    // ════════════════════════════════════════════════════════════════════════
    // SINGLE TICK LOOP
    // ════════════════════════════════════════════════════════════════════════

    setInterval(() => {
        addCalculatorButton();
        autofillPersonalBonus();
        autofillFreespins();
    }, 300);

})();
