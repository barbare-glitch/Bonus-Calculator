(function () {
    'use strict';

    // ════════════════════════════════════════════════════════════════════════
    // SHARED STATE
    // ════════════════════════════════════════════════════════════════════════

    let lastCalcResult = null;

    function getCurrentPlayerId() {
        return (location.pathname.match(/\/players\/(\d+)/) || [])[1] || null;
    }

    function getStoredRewardAmount(rewardType) {
        if (!lastCalcResult) return null;
        if (lastCalcResult.rewardType !== rewardType) return null;
        const playerId = getCurrentPlayerId();
        if (playerId && lastCalcResult.playerId && playerId !== lastCalcResult.playerId) return null;
        return lastCalcResult.rewardAmount || null;
    }


    // ════════════════════════════════════════════════════════════════════════
    // SECTION 1 — BONUS CALCULATOR
    // ════════════════════════════════════════════════════════════════════════

    const BLOCKING_TAGS = ['BA', 'Only VIP manager cashback'];

    const CRYPTO_MAP = {
        'BTC': 'bitcoin', 'ETH': 'ethereum', 'USDT': 'tether', 'LTC': 'litecoin',
        'SOL': 'solana', 'USDC': 'usd-coin', 'TON': 'the-open-network', 'TRX': 'tron',
        'XRP': 'ripple', 'BNB': 'binancecoin', 'DOGE': 'dogecoin', 'DOG': 'dogecoin',
        'BCH': 'bitcoin-cash', 'ADA': 'cardano'
    };

    function isCryptoCurrency(currency) {
        return Object.prototype.hasOwnProperty.call(CRYPTO_MAP, (currency || '').toUpperCase());
    }

    async function fetchUsdRate(currency) {
        const coinId = CRYPTO_MAP[(currency || '').toUpperCase()];
        if (!coinId) return null;
        try {
            const res = await fetch(`https://api.coingecko.com/api/v3/simple/price?ids=${coinId}&vs_currencies=usd`);
            const data = await res.json();
            return data?.[coinId]?.usd || null;
        } catch (e) {
            console.error('Bonus Calc: failed to fetch USD rate for', currency, e);
            return null;
        }
    }

    // Rounds a crypto amount to 8 decimal places (satoshi-level precision —
    // plenty for every coin we deal with) and returns it as a NUMBER, not a
    // string. This must happen exactly once, right where rewardAmount is
    // computed, so every downstream consumer (the result panel AND the
    // autofill scripts) works from the same clean value. Doing the rounding
    // only at display time (e.g. via toFixed in the template) leaves the
    // underlying stored number full of floating-point noise, which is what
    // was leaking into the Personal Bonus popup's amount field.
    function roundCrypto(amount) {
        return Math.round(amount * 1e8) / 1e8;
    }

